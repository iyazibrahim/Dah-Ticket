# Backend Environment Template
# Copy this to .env and fill in your actual values
# NEVER commit the actual .env file to Git!

# Server
PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-secure-password-here
DB_NAME=dahticket

# JWT Configuration
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-secure-secret-key-here-change-in-production
JWT_EXPIRATION_HOURS=24

# SLA Thresholds (in hours)
SLA_LOW_HOURS=48
SLA_MEDIUM_HOURS=24
SLA_HIGH_HOURS=8
SLA_CRITICAL_HOURS=2

# Email Configuration (Optional - for notifications)
# Leave blank to disable email functionality
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=your-email@company.com
SMTP_PASSWORD=your-app-password-or-token

# Organization Branding (Optional)
ORG_NAME=Your Company Name
ORG_LOGO_URL=https://example.com/logo.png
