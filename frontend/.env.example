# Frontend Environment Template
# Copy this to .env.local and fill in your actual values
# NEVER commit the actual .env.local file to Git!

# API Configuration — /api works for local dev (Vite proxy) and production (nginx proxy)
VITE_API_URL=/api

# Optional: Feature Flags
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_KB_MANAGEMENT=true
