# DahTicket V2 Environment Configuration Template

# Copy this file to .env in the root directory for docker-compose
# NEVER commit the actual .env file to Git!

# Backend Container
PORT=8080

# PostgreSQL Database
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me-to-a-secure-password
DB_NAME=dahticket

# JWT Configuration - MUST CHANGE IN PRODUCTION
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-secure-random-string-32-chars-minimum
JWT_EXPIRATION_HOURS=24

# SLA Configuration (hours)
SLA_LOW_HOURS=48
SLA_MEDIUM_HOURS=24
SLA_HIGH_HOURS=8
SLA_CRITICAL_HOURS=2

# Email Notifications (Optional)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=your-email@company.com
SMTP_PASSWORD=your-app-specific-password

# Frontend API URL (use /api for Docker/prod; Vite dev server proxies /api to backend)
VITE_API_URL=/api
