# Production environment — copy to .env on the server or set in Dokploy
# NEVER commit the real .env file!

# --- Required ---
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_NAME=dahticket
DB_PORT=5432

JWT_SECRET=change-me-openssl-rand-base64-32

# --- Application ---
PORT=8080
JWT_EXPIRATION_HOURS=24

# SLA targets (hours)
SLA_LOW_HOURS=48
SLA_MEDIUM_HOURS=24
SLA_HIGH_HOURS=8
SLA_CRITICAL_HOURS=2

# Email (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Frontend build — use relative path; nginx proxies /api to backend
VITE_API_URL=/api
